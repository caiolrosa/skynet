#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE=""
CONTAINER_NAME=""
CLEANUP_IN_PROGRESS=false
CLEANUP_DIRS=""

trap 'for d in $CLEANUP_DIRS; do rm -rf "$d"; done' EXIT

agent_install_cmd() {
  case "$1" in
    claude) echo "curl -fsSL https://claude.ai/install.sh | bash" ;;
    gemini) echo "npm install -g @google/gemini-cli" ;;
  esac
}

agent_binary() {
  case "$1" in
    claude) echo "claude" ;;
    gemini) echo "gemini" ;;
  esac
}

usage() {
  cat <<'EOF'
Usage: botrun [-f <config-file>] <command>

Commands:
  init     Create a default config file
  build    Build the Docker image from config
  run      Run the configured agent in a container

Options:
  -f <path>   Path to config file (default: .botrun.yaml in current directory)
  --help       Show this help message

Examples:
  botrun init
  botrun build
  botrun -f custom.yaml build
  botrun run
  botrun -f custom.yaml run
EOF
}

die() {
  echo "Error: $1" >&2
  exit "${2:-1}"
}

warn() {
  echo "Warning: $1" >&2
}

expand_tilde() {
  local path=$1 home=${2:-$HOME}
  case "$path" in
    "~"/*) echo "${home}/${path#\~/}" ;;
    "~")   echo "$home" ;;
    *)     echo "$path" ;;
  esac
}

check_docker() {
  if ! docker info > /dev/null 2>&1; then
    die "Docker is not installed or the daemon is not running. Please install Docker and ensure the daemon is started."
  fi
}

check_yq() {
  if ! command -v yq &> /dev/null; then
    die "yq is required but not installed. Install it from https://github.com/mikefarah/yq"
  fi
}

resolve_config() {
  if [[ -n "$CONFIG_FILE" ]]; then
    if [[ ! -f "$CONFIG_FILE" ]]; then
      die "Config file not found: $CONFIG_FILE"
    fi
  else
    CONFIG_FILE="$PWD/.botrun.yaml"
    if [[ ! -f "$CONFIG_FILE" ]]; then
      die "No .botrun.yaml found in current directory. Use -f to specify a config file."
    fi
  fi
}

parse_config() {
  check_yq
  resolve_config

  if ! yq eval '.' "$CONFIG_FILE" > /dev/null 2>&1; then
    local parse_error
    parse_error=$(yq eval '.' "$CONFIG_FILE" 2>&1 || true)
    die "Failed to parse config at $CONFIG_FILE: $parse_error"
  fi

  AGENT=$(yq eval '.agent // ""' "$CONFIG_FILE")
  if [[ -z "$AGENT" || "$AGENT" == "null" ]]; then
    die "Missing required field 'agent' in config"
  fi

  if [[ "$AGENT" != "claude" && "$AGENT" != "gemini" ]]; then
    die "Unsupported agent '$AGENT'. Supported agents: claude, gemini"
  fi

  PACKAGES=()
  while IFS= read -r pkg; do
    [[ -n "$pkg" && "$pkg" != "null" ]] && PACKAGES+=("$pkg")
  done < <(yq eval '.packages // [] | .[]' "$CONFIG_FILE" 2>/dev/null || true)

  MISE_TOOLS=()
  while IFS= read -r tool; do
    [[ -n "$tool" && "$tool" != "null" ]] && MISE_TOOLS+=("$tool")
  done < <(yq eval '.mise // [] | .[]' "$CONFIG_FILE" 2>/dev/null || true)

  VOLUMES=()
  while IFS= read -r vol; do
    [[ -n "$vol" && "$vol" != "null" ]] && VOLUMES+=("$vol")
  done < <(yq eval '.volumes // [] | .[]' "$CONFIG_FILE" 2>/dev/null || true)

  DOCKER_ENABLED=$(yq eval '.docker // "false"' "$CONFIG_FILE")
  if [[ "$DOCKER_ENABLED" != "true" ]]; then
    DOCKER_ENABLED="false"
  fi
}

generate_dockerfile() {
  local tmpdir="$1"
  local install_cmd
  install_cmd=$(agent_install_cmd "$AGENT")
  local binary_name
  binary_name=$(agent_binary "$AGENT")

  local all_packages=("curl" "git")
  if [[ "$DOCKER_ENABLED" == "true" ]]; then
    all_packages+=("ca-certificates")
  fi
  if [[ ${#PACKAGES[@]} -gt 0 ]]; then
    for pkg in "${PACKAGES[@]}"; do
      all_packages+=("$pkg")
    done
  fi
  local packages_str="${all_packages[*]}"

  local df=""
  df+='FROM ubuntu:24.04'$'\n'
  df+=$'\n'
  df+='ENV DEBIAN_FRONTEND=noninteractive'$'\n'
  df+=$'\n'
  df+="RUN apt-get update && \\"$'\n'
  df+="    apt-get install -y ${packages_str} && \\"$'\n'
  df+='    apt-get clean && \'$'\n'
  df+='    rm -rf /var/lib/apt/lists/*'$'\n'

  if [[ "$DOCKER_ENABLED" == "true" ]]; then
    df+=$'\n'
    df+='RUN install -m 0755 -d /etc/apt/keyrings && \'$'\n'
    df+='    curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc && \'$'\n'
    df+='    chmod a+r /etc/apt/keyrings/docker.asc && \'$'\n'
    df+='    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" > /etc/apt/sources.list.d/docker.list && \'$'\n'
    df+='    apt-get update && \'$'\n'
    df+='    apt-get install -y docker-ce-cli && \'$'\n'
    df+='    apt-get clean && \'$'\n'
    df+='    rm -rf /var/lib/apt/lists/*'$'\n'
  fi

  if [[ ${#MISE_TOOLS[@]} -gt 0 ]]; then
    df+=$'\n'
    df+='ENV PATH="/root/.local/share/mise/shims:/root/.local/bin:${PATH}"'$'\n'
    df+=$'\n'
    df+='RUN curl https://mise.run | sh'$'\n'

    local mise_cmds=""
    for tool in "${MISE_TOOLS[@]}"; do
      mise_cmds+="mise use --global ${tool} && "
    done
    mise_cmds+="mise reshim"

    df+=$'\n'
    df+="RUN ${mise_cmds}"$'\n'
  fi

  if [[ "$AGENT" == "claude" ]]; then
    df+=$'\n'
    df+='ENV PATH="/root/.local/bin:${PATH}"'$'\n'
  fi

  df+=$'\n'
  df+="RUN ${install_cmd}"$'\n'
  df+=$'\n'
  df+="ENTRYPOINT [\"/bin/bash\", \"-c\", \"${binary_name}\"]"$'\n'

  printf '%s' "$df" > "$tmpdir/Dockerfile"
}

cmd_build() {
  check_docker
  parse_config

  local tmpdir
  tmpdir=$(mktemp -d)
  CLEANUP_DIRS="$CLEANUP_DIRS $tmpdir"

  echo "Generating Dockerfile for agent '$AGENT'..."
  generate_dockerfile "$tmpdir"

  echo "Building image botrun:$AGENT..."
  if docker build -t "botrun:$AGENT" -f "$tmpdir/Dockerfile" "$tmpdir"; then
    echo "Image botrun:$AGENT built successfully"
  else
    die "Build failed — see output above for details"
  fi
}

cmd_init() {
  local target="$CONFIG_FILE"

  if [[ -z "$target" ]]; then
    read -rp "Config file path [.botrun.yaml]: " target
    [[ -z "$target" ]] && target=".botrun.yaml"
  fi

  target=$(expand_tilde "$target")

  if [[ -e "$target" ]]; then
    die "Config file already exists: $target"
  fi

  local parent
  parent="$(dirname "$target")"
  if [[ "$parent" != "." ]]; then
    mkdir -p "$parent"
  fi

  cat > "$target" <<'YAML'
# Required: the AI coding agent to use
# Supported values: claude, gemini
agent: claude

# Optional: additional apt packages to install in the container
# packages:
#   - git
#   - curl
#   - build-essential

# Optional: language runtimes and tools installed via mise (https://mise.jdx.dev)
# mise:
#   - node@22
#   - python@3.12

# Optional: additional volumes to mount (host:container)
# volumes:
#   - ~/.claude:~/.claude
#   - ~/.config/claude:~/.config/claude

# Optional: enable Docker access inside the container (mounts host Docker socket)
# docker: true
YAML

  echo "Created config file: $target"
}

check_orphaned_containers() {
  local containers
  containers=$(docker ps -a --filter label=botrun=true --format '{{.Names}} ({{.Status}})' 2>/dev/null || true)

  if [[ -z "$containers" ]]; then
    return
  fi

  echo "Found existing botrun containers:"
  echo "$containers"
  echo ""

  read -rp "Remove them before continuing? [Y/n] " answer
  case "${answer:-Y}" in
    [Yy]|"")
      local names
      names=$(docker ps -a --filter label=botrun=true --format '{{.Names}}')
      while IFS= read -r name; do
        docker rm -f "$name" > /dev/null 2>&1
        echo "Removed $name"
      done <<< "$names"
      ;;
    *)
      echo "Continuing with existing containers. You may experience conflicts."
      ;;
  esac
}

cleanup_container() {
  if $CLEANUP_IN_PROGRESS; then
    return
  fi
  CLEANUP_IN_PROGRESS=true

  trap '' SIGINT SIGTERM

  if [[ -n "$CONTAINER_NAME" ]]; then
    docker stop "$CONTAINER_NAME" > /dev/null 2>&1 || true
    docker rm -f "$CONTAINER_NAME" > /dev/null 2>&1 || true
  fi
}

cmd_run() {
  check_docker
  parse_config
  check_orphaned_containers

  local image="botrun:$AGENT"

  if ! docker image inspect "$image" > /dev/null 2>&1; then
    die "Image not found. Run 'botrun build' first."
  fi

  local timestamp
  timestamp=$(date +%s)
  CONTAINER_NAME="botrun-${AGENT}-${timestamp}"

  local -a run_args=(
    "-it"
    "--rm"
    "--name" "$CONTAINER_NAME"
    "--label" "botrun=true"
    "-e" "TERM=${TERM:-xterm-256color}"
    "-e" "COLORTERM=${COLORTERM:-truecolor}"
    "-v" "$PWD:$PWD"
    "-w" "$PWD"
  )

  local socket_mounted=false
  if [[ ${#VOLUMES[@]} -gt 0 ]]; then
    for vol in "${VOLUMES[@]}"; do
      local host_path container_path
      host_path="${vol%%:*}"
      container_path="${vol#*:}"

      host_path=$(expand_tilde "$host_path")
      container_path=$(expand_tilde "$container_path" "/root")

      if [[ "$host_path" == "/var/run/docker.sock" ]]; then
        socket_mounted=true
      fi

      if [[ ! -e "$host_path" ]]; then
        warn "Volume path $host_path not found on host, skipping"
        continue
      fi

      run_args+=("-v" "$host_path:$container_path")
    done
  fi

  if [[ "$DOCKER_ENABLED" == "true" ]]; then
    if [[ "$socket_mounted" == "true" ]]; then
      warn "Docker socket already mounted via volumes config, skipping automatic mount"
    else
      if [[ ! -S /var/run/docker.sock ]]; then
        die "Docker socket not found at /var/run/docker.sock — is Docker running?"
      fi
      run_args+=("-v" "/var/run/docker.sock:/var/run/docker.sock")
    fi
    warn "Docker access enabled — agent can control the host Docker daemon"
  fi

  trap 'cleanup_container; exit 130' SIGINT
  trap 'cleanup_container; exit 143' SIGTERM

  docker run "${run_args[@]}" "$image" || true

  trap - SIGINT SIGTERM
  CONTAINER_NAME=""
}

# Parse global flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    -f)
      if [[ $# -lt 2 ]]; then
        die "Option -f requires a file path"
      fi
      CONFIG_FILE="$2"
      shift 2
      ;;
    --help)
      usage
      exit 0
      ;;
    -*)
      die "Unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

COMMAND="${1:-}"

case "$COMMAND" in
  "")
    usage
    exit 0
    ;;
  init)
    cmd_init
    ;;
  build)
    cmd_build
    ;;
  run)
    cmd_run
    ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    usage >&2
    exit 1
    ;;
esac
